<mujoco model="qmini_terrain">
	<!-- Self-contained terrain-training world for qmini.

	     A progressive obstacle course laid out along +X (robot spawns at the origin
	     facing +X). Difficulty ramps up zone by zone:
	       A  x<1.5      flat start / settle
	       B  1.6-3.4    rough uneven ground (protruding tiles)
	       C  3.7-5.1    washboard / wavy bumps
	       D  5.5-7.7    gentle hill (ramp up, plateau, ramp down)
	       E  8.0-10.6   small stairs up to a landing, then down
	       F  10.9-12.1  raised stepping platforms (zig-zag foot placement)
	       G  12.8-14.0  step-over barriers (increasing height)
	       H  x>14.5     flat finish

	     Ground is a flat plane at z=0 (same as scene.xml's floor), but this world
	     does NOT include scene.xml — it defines its own fog/lighting. It pulls
	     in dependencies.xml only (compiler +
	     mesh + plane-material assets) and defines its own option/visual/lights here.
	     All obstacles are additive boxes resting on the ground; the infinite ground
	     plane is always underfoot, so stepping off an obstacle is a small drop, not
	     a fall into a void. -->

	<include file="dependencies.xml"/>

	<option timestep='0.001' iterations="50" tolerance="1e-10" solver="Newton" jacobian="dense" cone="elliptic"/>

	<visual>
		<map fogstart="3" fogend="12" force="0.1" znear="0.1"/>
		<quality shadowsize="4096" offsamples="4"/>
		<headlight ambient="0.4 0.4 0.4"/>
	</visual>

	<asset>
		<texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="512" height="512"/>
	</asset>

	<worldbody>
		<light castshadow="false" directional="true" diffuse=".3 .3 .3" specular="0.3 0.3 0.3" pos="-2 -2 4" dir="1 1 -2"/>
		<light directional="true" diffuse=".3 .3 .3" specular="0.3 0.3 0.3" pos="6 -2 4" dir="-1 1 -2"/>
		<light castshadow="false" directional="true" diffuse=".3 .3 .3" specular="0.3 0.3 0.3" pos="6 2 4" dir="0 -1 -2"/>

		<!-- flat ground at z=0 (infinite plane, always underfoot) -->
		<geom name="floor" type="plane" pos="0 0 0" size="0 0 0.05" material="matplane" condim="3" friction="1.0 0.005 0.0001" solref="0.004 1" solimp="0.95 0.99 0.001"/>

		<!-- the robot body tree (base_link free body + leg chains) -->
		<include file="qmini_description.xml"/>

		<!-- ===================== progressive terrain course ===================== -->
		<!-- Zone B: rough uneven ground (small protruding tiles) -->
		<geom name="rough_0_0" type="box" pos="1.7 -0.45 0.0000" size="0.13 0.13 0.004" quat="0.99985 0 -0.01745 0" rgba="0.55 0.5 0.45 1" condim="3" friction="1.0 0.005 0.0001" solref="0.004 1" solimp="0.95 0.99 0.001"/>
		<geom name="rough_0_1" type="box" pos="1.7 -0.15 0.0000" size="0.13 0.13 0.00416" rgba="0.55 0.5 0.45 1" condim="3" friction="1.0 0.005 0.0001" solref="0.004 1" solimp="0.95 0.99 0.001"/>
		<geom name="rough_0_2" type="box" pos="1.7 0.15 0.0000" size="0.13 0.13 0.00432" quat="0.99985 0 0.01745 0" rgba="0.55 0.5 0.45 1" condim="3" friction="1.0 0.005 0.0001" solref="0.004 1" solimp="0.95 0.99 0.001"/>
